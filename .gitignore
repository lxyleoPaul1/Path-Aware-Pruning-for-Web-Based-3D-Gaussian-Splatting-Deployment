weights/
data/
datasets/

# Evaluation caches and temporary render outputs
experiments/**/cache/
experiments/**/output/cache/
experiments/**/output/logs/
experiments/**/output/visual/
experiments/**/output/renders/
experiments/**/output/rendered/
experiments/**/output/tmp/
